generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                 Int     @id @default(autoincrement())
  nombre             String
  usuario            String  @unique
  correo             String  @unique
  id_pais            Int
  id_rol             Int
  id_metodo_pago_fav Int

  pais             Pais        @relation(fields: [id_pais], references: [id])
  rol              Rol         @relation(fields: [id_rol], references: [id])
  metodo_pago_fav  Metodo_Pago @relation(fields: [id_metodo_pago_fav], references: [id])

  productos        Producto[]         @relation("ProductoVendedor")
  ventas           Venta[]
  carrito          Carrito[]
  productos_deseados Producto_Deseado[]
}

model Producto {
  id           Int    @id @default(autoincrement())
  nombre       String
  descripcion  String
  id_vendedor  Int
  id_categoria Int
  id_pais      Int

  vendedor  Usuario   @relation("ProductoVendedor", fields: [id_vendedor], references: [id])
  categoria Categoria @relation(fields: [id_categoria], references: [id])
  pais      Pais      @relation(fields: [id_pais], references: [id])

  ventas_x_producto Venta_x_Producto[]
  carrito           Carrito[]
  deseados          Producto_Deseado[]
  precios           Precio[]
}

model Categoria {
  id     Int    @id @default(autoincrement())
  nombre String

  productos Producto[]
}

model Pais {
  id     Int    @id @default(autoincrement())
  nombre String

  usuarios  Usuario[]
  productos Producto[]
  precios   Precio[]
}

model Rol {
  id     Int    @id @default(autoincrement())
  nombre String

  usuarios Usuario[]
}

model Metodo_Pago {
  id     Int    @id @default(autoincrement())
  nombre String

  usuarios_fav Usuario[]
  ventas       Venta[]
}

model Venta {
  id          Int @id @default(autoincrement())
  id_usuario  Int
  metodo_pago Int

  usuario      Usuario     @relation(fields: [id_usuario], references: [id])
  metodoPago   Metodo_Pago @relation(fields: [metodo_pago], references: [id])

  ventas_x_producto Venta_x_Producto[]
}

model Venta_x_Producto {
  id          Int   @id @default(autoincrement())
  id_producto Int
  id_venta    Int
  cantidad    Int
  precio      Float

  producto Producto @relation(fields: [id_producto], references: [id])
  venta    Venta    @relation(fields: [id_venta], references: [id])
}

model Carrito {
  id          Int @id @default(autoincrement())
  id_producto Int
  id_usuario  Int

  producto Producto @relation(fields: [id_producto], references: [id])
  usuario  Usuario  @relation(fields: [id_usuario], references: [id])
}

model Producto_Deseado {
  id          Int @id @default(autoincrement())
  id_producto Int
  id_usuario  Int

  producto Producto @relation(fields: [id_producto], references: [id])
  usuario  Usuario  @relation(fields: [id_usuario], references: [id])
}

model Precio {
  id          Int   @id @default(autoincrement())
  id_producto Int
  id_pais     Int
  precio      Float

  producto Producto @relation(fields: [id_producto], references: [id])
  pais     Pais     @relation(fields: [id_pais], references: [id])
}

model Videojuego {
  id     Int    @id @default(autoincrement())
  nombre String
}
